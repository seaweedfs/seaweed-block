# Go toolchain caches (if GOCACHE/GOTMPDIR is pointed at the workspace)
.gocache/
.gotmp/

# Built binaries at repo root (sparrow is a command; tests build their own
# transient copies). Anchored with / so these do NOT match the cmd/sparrow/
# source directory's files.
/sparrow
/sparrow.exe

# Test coverage artifacts
*.test
*.out
coverage.out

# G5-5* cross-compile artifacts (m01 hardware iteration script
# stages binaries into _g5_bin/ before scp to the test host; root-
# level *.exe are Windows-side build outputs that go build leaves
# behind on iteration runs).
/_g5_bin/
/blockmaster
/blockmaster.exe
/blockvolume
/blockvolume.exe
