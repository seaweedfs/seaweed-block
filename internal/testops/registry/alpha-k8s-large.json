    "nodes.before.txt",
    "block-stack.rendered.yaml",
    "apply-block-stack.log",
    "apply-rbac.log",
    "apply-csidriver.log",
    "apply-csi-controller.log",
    "apply-csi-node.log",
    "apply-dynamic.log",
