FROM golang:1.25-bookworm AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/blockmaster ./cmd/blockmaster && \
    CGO_ENABLED=0 go build -o /out/blockvolume ./cmd/blockvolume

FROM debian:bookworm-slim

COPY --from=build /out/blockmaster /usr/local/bin/blockmaster
COPY --from=build /out/blockvolume /usr/local/bin/blockvolume

USER 65532:65532
